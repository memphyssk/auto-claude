#!/usr/bin/env bash
# auto-claude capabilities — enumerate runtime-callable tools.
#
# Produces a compact "capability sheet" that tells the agent what's actually
# installed + registered + callable on this machine, right now. Meant to be
# invoked at session start and cached to Planning/.capability-sheet.md.
#
# Enumerates:
#   - Global CLIs (via `command -v`)
#   - Claude Code skills (via ls ~/.claude/skills)
#   - Claude Code agents (via ls ~/.claude/agents)
#   - Registered MCP servers (via parsing ~/.mcp.json + ~/.claude.json)
#
# Output is plain markdown, <50 lines typically. Consumed by always-on rule #11.

set -o errexit
set -o pipefail

# ── CLIs we care about for enumeration (extend as needed) ──
CLIS_TO_CHECK=(
  gh task-master playwright-mcp domain-mcp netlify railway
  agentmail resend rtk bun pnpm pass
)

# ── Output header ──
cat <<EOF
# Capability sheet — $(date -u +%Y-%m-%dT%H:%M:%SZ)

**What's actually callable on this machine right now.** Generated by
\`auto-claude capabilities\`. Refresh if session spans >1 hour or if
\`/update-tools\` installs new tools.

Before deferring to the founder on any operational task, check this
sheet and consider whether an available tool can do it autonomously.
See CLAUDE.md always-on rule #11.

EOF

# ── CLIs ──
echo "## CLIs on \$PATH"
echo
missing=()
present=()
for cli in "${CLIS_TO_CHECK[@]}"; do
  if command -v "$cli" >/dev/null 2>&1; then
    present+=("$cli")
  else
    missing+=("$cli")
  fi
done
if ((${#present[@]})); then
  printf -- '- %s\n' "${present[@]}"
fi
if ((${#missing[@]})); then
  echo
  echo "_Not installed: ${missing[*]}_"
fi
echo

# ── Skills ──
echo "## Skills at ~/.claude/skills/"
echo
if [[ -d "$HOME/.claude/skills" ]]; then
  count=$(ls -1 "$HOME/.claude/skills" 2>/dev/null | wc -l | tr -d ' ')
  echo "$count skills installed. Invoke as \`/<skill-name>\`. Key ones:"
  # Cherry-pick the skills the brain references most
  for skill in office-hours plan-ceo-review plan-eng-review autoplan \
               review qa qa-only cso investigate retro learn ship \
               land-and-deploy health browse canary benchmark codex \
               design-review careful freeze guard update-tools; do
    if [[ -d "$HOME/.claude/skills/$skill" ]]; then
      echo "- /$skill"
    fi
  done
else
  echo "_No ~/.claude/skills directory — skills not installed._"
fi
echo

# ── Agents ──
echo "## Agents at ~/.claude/agents/"
echo
if [[ -d "$HOME/.claude/agents" ]]; then
  count=$(ls -1 "$HOME/.claude/agents" 2>/dev/null | wc -l | tr -d ' ')
  echo "$count agents installed. Spawn via the Task tool. Key ones for brain use:"
  for agent in Jenny karen ceo-reviewer founder-proxy competitive-analyst \
               architect-reviewer ux-researcher risk-manager product-manager \
               problem-framer knowledge-synthesizer backend-developer \
               frontend-developer nextjs-developer react-specialist \
               refactoring-specialist security-engineer ui-designer \
               ui-comprehensive-tester; do
    if [[ -f "$HOME/.claude/agents/${agent}.md" ]]; then
      echo "- $agent"
    fi
  done
else
  echo "_No ~/.claude/agents directory — agents not installed._"
fi
echo

# ── MCP servers ──
echo "## MCP servers (registered for this machine)"
echo
echo "From \`~/.mcp.json\` + \`~/.claude.json\` (user-scope):"
{
  # User-scope ~/.mcp.json
  if [[ -f "$HOME/.mcp.json" ]]; then
    python3 -c "
import json, sys
try:
    d = json.load(open('$HOME/.mcp.json'))
    for name in d.get('mcpServers', {}).keys():
        print(f'- {name}')
except Exception as e:
    print(f'_parse error on ~/.mcp.json: {e}_', file=sys.stderr)
" 2>/dev/null
  fi

  # Per-project from ~/.claude.json
  if [[ -f "$HOME/.claude.json" ]]; then
    python3 -c "
import json, sys
try:
    d = json.load(open('$HOME/.claude.json'))
    servers = set(d.get('mcpServers', {}).keys())
    for proj, cfg in d.get('projects', {}).items():
        servers.update(cfg.get('mcpServers', {}).keys())
    for name in sorted(servers):
        print(f'- {name}')
except Exception as e:
    print(f'_parse error on ~/.claude.json: {e}_', file=sys.stderr)
" 2>/dev/null
  fi
} | sort -u

echo
echo "Plus any \`.mcp.json\` in the current project root (check \$PWD/.mcp.json)."
echo

# ── Brain-sync tool reminder ──
echo "## Brain sync"
echo
if command -v auto-claude >/dev/null 2>&1; then
  ac_path=$(command -v auto-claude)
  echo "- \`auto-claude\` available at $ac_path"
elif [[ -x "$HOME/auto-claude/bin/auto-claude" ]]; then
  echo "- \`~/auto-claude/bin/auto-claude\` — tool is there but not on PATH"
else
  echo "_Not found. See setup-tools/install.md § Brain sync._"
fi
echo

# ── Footer ──
cat <<'EOF'
---

**When this sheet says a tool is present, use it autonomously instead of asking
the founder.** When it says a tool is missing but the task needs it, check
`command-center/setup-tools/install.md` for install commands before asking.

Sheet staleness: regenerate via `auto-claude capabilities > Planning/.capability-sheet.md`
when session >1h or after `/update-tools` runs.
EOF
